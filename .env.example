# HR Buddy QA — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Groq — LLM de avaliação do DeepEval e juiz do Promptfoo (gratuito em console.groq.com)
GROQ_API_KEY=gsk_...

# Webhook n8n — obrigatório para todos os testes
N8N_WEBHOOK_URL=https://SEU_WORKSPACE.app.n8n.cloud/webhook/hr-buddy

# Promptfoo — usa Groq como LLM juiz via endpoint OpenAI-compatível
# Não é necessário duplicar a chave; o conftest.py já configura isso para DeepEval.
# Para o Promptfoo (processo Node.js separado), adicione manualmente se necessário:
# OPENAI_API_KEY=  # mesmo valor que GROQ_API_KEY
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
